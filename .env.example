# Vercel → Project Settings → Environment Variables
# NEVER commit the real API key or expose it in frontend JavaScript.

PI_API_KEY=your_server_api_key_from_develop_pi_portal

# App ID is configured in the Pi Developer Portal (develop.pi in Pi Browser).
# Link your production URL: https://pioneer-wall.vercel.app
# The App ID is not pasted into client code — Pi matches your app by domain.
